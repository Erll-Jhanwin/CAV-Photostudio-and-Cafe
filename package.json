{
  "name": "cav-capacitor",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "build": "npm --workspace frontend run build",
    "cap": "cap",
    "cap:copy": "npm run build && cap copy android",
    "cap:sync": "npm run build && cap sync android",
    "cap:open:android": "cap open android",
    "cap:run:android": "npm run cap:sync && cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2"
  }
}
