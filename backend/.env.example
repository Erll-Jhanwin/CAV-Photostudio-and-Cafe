DJANGO_DEBUG=false
DJANGO_SECRET_KEY=generate-a-long-random-production-secret
DJANGO_ALLOWED_HOSTS=your-backend.onrender.com
TIME_ZONE=Asia/Manila
DATABASE_TIME_ZONE=Asia/Manila

# Supabase / PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_SSL_REQUIRE=true

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_PRELOAD=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Email/password reset settings. Render free services cannot use SMTP ports;
# configure Resend below for deployed password reset emails.
EMAIL_PROVIDER=smtp
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=CAV Photo Studio & Cafe <no-reply@cav.local>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=20
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails

# OCR receipt scanning API. Set OCR_API_KEY only in backend env/Render, never in frontend code.
OCR_API_PROVIDER=ocr_space
OCR_API_URL=https://api.ocr.space/parse/image
OCR_API_KEY=your-ocr-provider-secret
OCR_API_TIMEOUT=20
OCR_SPACE_ENGINE=2
OCR_FALLBACK_TESSERACT=true

# Optional local OCR fallback path. Render Docker image uses /usr/bin/tesseract.
TESSERACT_CMD=/usr/bin/tesseract

# API abuse controls
DRF_ANON_THROTTLE_RATE=60/minute
DRF_USER_THROTTLE_RATE=600/minute
DRF_AUTH_THROTTLE_RATE=10/minute
DRF_PASSWORD_RESET_THROTTLE_RATE=3/hour
DRF_SENSITIVE_THROTTLE_RATE=12/minute
